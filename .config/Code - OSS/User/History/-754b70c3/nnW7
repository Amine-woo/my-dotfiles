{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["custom/launcher", "hyprland/workspaces","custom/swaync"],
    "modules-center": ["clock","custom/updates"],
    "modules-right": ["tray", "pulseaudio", "network", "bluetooth", "backlight", "battery", "power-profiles-daemon", "custom/lock" ],
    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "о®µ",
            "2": "о®µ",
            "3": "о®µ",
            "4": "о®µ",
            "5": "о®µ",
            "urgent": "п„‘",
            "active": "п„‘",
            "default": "п„‘"
         },
     },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "custom/launcher":{
        "format": "пЊѓ ",
        "on-click": "rofi -show drun",
        "on-click-right": "killall rofi",
        "tooltip": false
    },

    "clock": {
        "timezone": "Africa/Casablanca",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "пЃі  {:%d/%m/%Y}",
        "format": "пЂ—  {:%I:%M %p}"
    },

    "backlight": {
        "device": "intel_backlight",
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
        "on-click": "brightnessctl -r",
				"on-scroll-up": "brightnessctl set 2%+",
        "on-scroll-down": "brightnessctl set 2%-",
        "min-length": 6
    },
 
    "bluetooth": {
	"controller": "blueman",
	"format": "пЉ”",
	"format-disabled": "пЉ”",
	"format-off": "пЉ” off",
	"on-click": "~/.config/rofi/bluetooth.sh",
	"on-click-right": "blueman-manager"
    },
    
  "custom/swaync": {
    "tooltip": false,
    "format": "{} {icon}",
    "format-icons": {
      "notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
      "none": "п‚ў",
      "dnd-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-none": "п‡·",
      "inhibited-notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
      "inhibited-none": "п‚ў",
      "dnd-inhibited-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-inhibited-none": "п‡·",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-charging": "у°‚„ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
        "format-alt": "{icon}",
        "format-icons": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-muted": "о»Ё ",
        "format-icons": {
            "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ "]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol",
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "wlogout",
        "on-click-right": "killall rofi",
        "format": "вЏ» ",
    },
    
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "{profile}",
        "tooltip": true,
        "format-icons": {
            "performance": "у°“…",
            "balanced": "у°ѕ…",
