    },

    "custom/updates": {
        "format": "п‚«  {}",
        "escape": true,
        "return-type": "text",
        "exec": "~/.config/waybar/update.sh",
        "restart-interval": 60,
        "on-click": "kitty -e sudo pacman -Syu",
    },

    "niri/language": {
        "format": "п„њ  {short}",
    },
        "network": {
        "interface": "wlan0",

        "format": "{ifname}",
        "format-disconnected": "п„Є",

        "format-wifi": "п‡«  {essid}",
        "tooltip-format": "{signalStrength}%",
        "tooltip-format-wifi": "{essid} {signalStrength}%",
        "tooltip-format-disconnected": "No Connection",
